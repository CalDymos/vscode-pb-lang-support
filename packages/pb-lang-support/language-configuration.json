{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(Procedure(?:C|DLL|CDLL)?|If|For(?:Each)?|While|Repeat|Select|Structure|Interface|Enumeration(?:Binary)?|Module|DeclareModule|Macro|DataSection|CompilerIf|CompilerSelect|With)\\b",
      "end": "^\\s*(EndProcedure|EndIf|Next|Wend|Until|ForEver|EndSelect|EndStructure|EndInterface|EndEnumeration|EndModule|EndDeclareModule|EndMacro|EndDataSection|CompilerEndIf|CompilerEndSelect|EndWith)\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(Procedure(?:C|DLL|CDLL)?\\b|Module\\b|DeclareModule\\b|Structure\\b|Interface\\b|Enumeration(?:Binary)?\\b|If\\b|For\\b|ForEach\\b|While\\b|Repeat\\b|Select\\b|With\\b|Macro\\b|DataSection\\b|CompilerIf\\b|CompilerSelect\\b)",
    "decreaseIndentPattern": "^\\s*(EndProcedure\\b|EndModule\\b|EndDeclareModule\\b|EndStructure\\b|EndInterface\\b|EndEnumeration\\b|EndIf\\b|Next\\b|Wend\\b|Until\\b|ForEver\\b|EndSelect\\b|EndWith\\b|EndMacro\\b|EndDataSection\\b|CompilerEndIf\\b|CompilerEndSelect\\b)"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "autocomplete": {
    "triggerCharacters": [".", "(", " "]
  }
}
