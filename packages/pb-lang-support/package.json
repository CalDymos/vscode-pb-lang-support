{
  "name": "pb-lang-support",
  "displayName": "PureBasic Language Services",
  "description": "%extension.description%",
  "version": "0.18.0",
  "publisher": "CalDymos",
  "author": {
    "name": "CalDymos"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite.git",
    "directory": "packages/pb-lang-support"
  },
  "bugs": {
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite/issues"
  },
  "homepage": "https://github.com/CalDymos/vscode-pb-lang-suite/tree/main/packages/pb-lang-support",
  "license": "MIT",
  "keywords": [
    "purebasic",
    "pb",
    "language",
    "syntax",
    "highlighting",
    "intellisense",
    "autocomplete"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:purebasic",
    "onDebugResolve:purebasic",
    "onDebugAdapterProtocolTracker:purebasic"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "%theme.constantsHighlight.label%",
        "uiTheme": "vs-dark",
        "path": "./themes/purebasic-constants-color-theme.json"
      }
    ],
    "configuration": {
      "title": "PureBasic",
      "properties": {
        "purebasic.maxNumberOfProblems": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "description": "%config.purebasic.maxNumberOfProblems.description%"
        },
        "purebasic.enableValidation": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.enableValidation.description%"
        },
        "purebasic.enableCompletion": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.enableCompletion.description%"
        },
        "purebasic.validationDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "%config.purebasic.validationDelay.description%"
        },
        "purebasic.apiFunctionListingPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.purebasic.apiFunctionListingPath.description%"
        },
        "purebasic.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.formatting.enabled.description%"
        },
        "purebasic.formatting.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "%config.purebasic.formatting.indentSize.description%"
        },
        "purebasic.formatting.tabSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "%config.purebasic.formatting.tabSize.description%"
        },
        "purebasic.formatting.insertSpaces": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.formatting.insertSpaces.description%"
        },
        "purebasic.formatting.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.formatting.trimTrailingWhitespace.description%"
        },
        "purebasic.formatting.trimFinalNewlines": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.formatting.trimFinalNewlines.description%"
        },
        "purebasic.completion.triggerCharacters": {
          "type": "array",
          "default": [".", "(", "["],
          "description": "%config.purebasic.completion.triggerCharacters.description%"
        },
        "purebasic.completion.autoClosingPairs": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.completion.autoClosingPairs.description%"
        },
        "purebasic.completion.suggestOnType": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.completion.suggestOnType.description%"
        },
        "purebasic.linting.enableSemanticValidation": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.linting.enableSemanticValidation.description%"
        },
        "purebasic.linting.checkUnusedVariables": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.linting.checkUnusedVariables.description%"
        },
        "purebasic.linting.checkUndefinedSymbols": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.linting.checkUndefinedSymbols.description%"
        },
        "purebasic.linting.enableCodeActions": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.linting.enableCodeActions.description%"
        },
        "purebasic.symbols.enableWorkspaceSymbols": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.symbols.enableWorkspaceSymbols.description%"
        },
        "purebasic.symbols.cacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.symbols.cacheEnabled.description%"
        },
        "purebasic.symbols.cacheSize": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.purebasic.symbols.cacheSize.description%"
        },
        "purebasic.performance.enableIncrementalParsing": {
          "type": "boolean",
          "default": true,
          "description": "%config.purebasic.performance.enableIncrementalParsing.description%"
        },
        "purebasic.performance.maxFileSize": {
          "type": "number",
          "default": 1048576,
          "minimum": 102400,
          "description": "%config.purebasic.performance.maxFileSize.description%"
        },
        "purebasic.build.fallbackSource": {
          "type": "string",
          "enum": [
            "sourceMetadata",
            "launchJson",
            "fileCfg",
            "projectCfg"
          ],
          "enumDescriptions": [
            "%config.purebasic.build.fallbackSource.sourceMetadata.description%",
            "%config.purebasic.build.fallbackSource.launchJson.description%",
            "%config.purebasic.build.fallbackSource.fileCfg.description%",
            "%config.purebasic.build.fallbackSource.projectCfg.description%"
          ],
          "default": "launchJson",
          "description": "%config.purebasic.build.fallbackSource.description%"
        },
        "purebasic.build.compiler": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.purebasic.build.compiler.description%"
        },
        "purebasic.run.mode": {
          "type": "string",
          "enum": ["spawn", "terminal"],
          "enumDescriptions": [
            "%config.purebasic.run.mode.spawn.description%",
            "%config.purebasic.run.mode.terminal.description%"
          ],
          "default": "spawn",
          "description": "%config.purebasic.run.mode.description%",
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "purebasic.showDiagnostics",
        "title": "%command.showDiagnostics.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.restartLanguageServer",
        "title": "%command.restartLanguageServer.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.clearSymbolCache",
        "title": "%command.clearSymbolCache.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.formatDocument",
        "title": "%command.formatDocument.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.findSymbols",
        "title": "%command.findSymbols.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.buildActiveTarget",
        "title": "%command.buildActiveTarget.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.runActiveTarget",
        "title": "%command.runActiveTarget.title%",
        "category": "PureBasic"
      },
      {
        "command": "purebasic.buildAndRunActiveTarget",
        "title": "%command.buildAndRunActiveTarget.title%",
        "category": "PureBasic"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "purebasic.showDiagnostics",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.restartLanguageServer",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.clearSymbolCache",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.formatDocument",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.findSymbols",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.buildActiveTarget",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.runActiveTarget",
          "when": "editorLangId == purebasic"
        },
        {
          "command": "purebasic.buildAndRunActiveTarget",
          "when": "editorLangId == purebasic"
        }
      ],
      "editor/context": [
        {
          "command": "purebasic.formatDocument",
          "when": "editorLangId == purebasic",
          "group": "1_modification"
        }
      ]
    },
    "languages": [
      {
        "id": "purebasic",
        "aliases": [
          "PureBasic",
          "purebasic"
        ],
        "extensions": [
          ".pb",
          ".pbi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/purebasic.png",
          "dark": "./icons/purebasic.png"
        }
      },
      {
        "id": "purebasic-form",
        "aliases": [
          "PureBasic Form",
          "purebasic-form"
        ],
        "extensions": [
          ".pbf"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/purebasic.png",
          "dark": "./icons/purebasic.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "purebasic",
        "scopeName": "source.purebasic",
        "path": "./syntaxes/purebasic.tmLanguage.json"
      },
      {
        "language": "purebasic-form",
        "scopeName": "source.purebasic.form",
        "path": "./syntaxes/purebasic-form.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "purebasic",
        "path": "./snippets/purebasic.json"
      },
      {
        "language": "purebasic-form",
        "path": "./snippets/purebasic.json"
      }
    ],
    "debuggers": [
      {
        "type": "purebasic",
        "label": "PureBasic",
        "runtime": "node",
        "program": "./out/debug/debugAdapter.js",
        "languages": [
          "purebasic"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "%debugger.launch.program.description%",
                "default": "${file}"
              },
              "compiler": {
                "type": "string",
                "description": "%debugger.launch.compiler.description%",
                "default": "pbcompiler"
              },
              "compilerArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%debugger.launch.compilerArgs.description%"
              },
              "cwd": {
                "type": "string",
                "description": "%debugger.launch.cwd.description%"
              },
              "output": {
                "type": "string",
                "description": "%debugger.launch.output.description%"
              },
              "runCwd": {
                "type": "string",
                "description": "%debugger.launch.runCwd.description%"
              },
              "runArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "%debugger.launch.runArgs.description%"
              },
              "transport": {
                "type": "string",
                "enum": [
                  "auto",
                  "pipe",
                  "network",
                  "fifo",
                  "native"
                ],
                "description": "%debugger.launch.transport.description%",
                "default": "auto"
              },
              "debugHost": {
                "type": "string",
                "description": "%debugger.launch.debugHost.description%",
                "default": "127.0.0.1"
              },
              "debugPort": {
                "type": "number",
                "minimum": 0,
                "maximum": 65535,
                "description": "%debugger.launch.debugPort.description%",
                "default": 0
              },
              "debugPassword": {
                "type": "string",
                "description": "%debugger.launch.debugPassword.description%"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "%debugger.launch.stopOnEntry.description%",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "%debugger.launch.trace.description%",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "purebasic",
            "request": "launch",
            "name": "%debugger.initialConfiguration.debugPureBasic.name%",
            "program": "${file}",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "%debugger.configurationSnippet.debugCurrentFile.label%",
            "description": "%debugger.configurationSnippet.debugCurrentFile.description%",
            "body": {
              "type": "purebasic",
              "request": "launch",
              "name": "%debugger.initialConfiguration.debugPureBasic.name%",
              "program": "^\"${1:\\${file}}\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "purebasic"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run webpack:prod",
    "typecheck": "tsc -p ./ --noEmit",
    "compile": "tsc -p ./",
    "watch": "tsc -w",
    "webpack": "webpack --mode development --config webpack.config.js",
    "webpack:prod": "webpack --mode production --config webpack.config.js",
    "webpack:watch": "webpack --mode development --watch",
    "test": "jest",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.1",
    "vscode-uri": "^3.1.0",
    "jsonc-parser": "^3.2.0",
    "@caldymos/pb-project-core": "file:../pb-project-core"
  },
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "jest": "^30.1.3",
    "jest-environment-node": "^30.1.2",
    "sharp": "^0.34.3",
    "typescript": "^5.9.2",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.4",
    "source-map-loader": "^5.0.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "extensionPack": [],
  "extensionDependencies": []
}
