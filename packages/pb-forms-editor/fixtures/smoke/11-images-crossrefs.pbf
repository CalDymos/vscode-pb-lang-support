; Form Designer for PureBasic - 6.20
;
; EnableExplicit
;
;   Warning: This file is generated by the Form Designer.
;            Manual changes will be lost after recompilation!

Enumeration FormWindow
  #FrmImages
EndEnumeration

Enumeration FormGadget
  #ImgPreview
EndEnumeration

OpenWindow(#FrmImages, 0, 0, 320, 180, "Images")
LoadImage(#ImgOpen, "open.png")
imgSave = LoadImage(#PB_Any, "save.png")
CatchImage(#ImgState, ?ImgState)
ImageGadget(#ImgPreview, 10, 10, 32, 32, ImageID(#ImgOpen))
CreateMenu(#MenuMain, WindowID(#FrmImages))
MenuItem(#MenuOpen, "Open", ImageID(#ImgOpen))
CreateToolBar(#TbMain, WindowID(#FrmImages))
ToolBarImageButton(#TbSave, ImageID(imgSave))
ToolBarToolTip(#TbMain, #TbSave, "Save")
CreateStatusBar(#SbMain, WindowID(#FrmImages))
AddStatusBarField(#PB_Ignore)
StatusBarImage(#SbMain, 0, ImageID(#ImgState))

DataSection
  ImgState:
  Data.b 0
EndDataSection

; IDE Options = PureBasic 6.20 LTS (Windows - x64)
