{
  "name": "pb-project-files",
  "displayName": "PureBasic Project Files",
  "description": "Workspace project/target management for PureBasic (.pbp) projects",
  "version": "0.7.0",
  "publisher": "CalDymos",
  "author": {
    "name": "CalDymos"
  },
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite.git",
    "directory": "packages/pb-project-files"
  },
  "bugs": {
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite/issues"
  },
  "homepage": "https://github.com/CalDymos/vscode-pb-lang-suite/tree/main/packages/pb-project-files",
  "keywords": [
    "purebasic",
    "pbp",
    "project",
    "project files",
    "targets",
    "build targets",
    "project manager",
    "custom editor",
    "webview"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.pbp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "%purebasicProjectEditor.configuration.title%",
      "properties": {
        "purebasicProjectEditor.inactiveTabForeground": {
          "type": "string",
          "default": "",
          "description": "%purebasicProjectEditor.inactiveTabForeground.description%"
        }
      }
    },
    "commands": [
      {
        "command": "pbProjectFiles.pickProject",
        "title": "PureBasic: Select Active Project",
        "category": "PureBasic"
      },
      {
        "command": "pbProjectFiles.pickTarget",
        "title": "PureBasic: Select Active Target",
        "category": "PureBasic"
      },
      {
        "command": "pbProjectFiles.refresh",
        "title": "PureBasic: Refresh Projects",
        "category": "PureBasic"
      }
    ],
    "customEditors": [
      {
        "viewType": "pbProjectFiles.pbpEditor",
        "displayName": "PureBasic Project",
        "selector": [
          {
            "filenamePattern": "*.pbp"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./ && webpack --mode development --config webpack.config.js",
    "watch": "concurrently \"tsc -w -p ./\" \"webpack --mode development --watch --config webpack.config.js\"",
    "webpack:prod": "webpack --mode production --config webpack.config.js",
    "webpack:dev": "webpack --mode development --config webpack.config.js",
    "vscode:prepublish": "npm run compile && npm run webpack:prod"
  },
  "dependencies": {
    "@caldymos/pb-project-core": "file:../pb-project-core"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.2",
    "ts-loader": "^9.5.4",
    "source-map-loader": "^5.0.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "extensionDependencies": []
}
